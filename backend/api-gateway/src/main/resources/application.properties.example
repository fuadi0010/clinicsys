# =====================================
# APPLICATION
# =====================================
spring.application.name=api-gateway
server.port=8080

# =====================================
# ROUTING CONFIGURATION (MICROSERVICES)
# =====================================

# AUTH SERVICE
spring.cloud.gateway.routes[0].id=auth-service
spring.cloud.gateway.routes[0].uri=http://localhost:8081
spring.cloud.gateway.routes[0].predicates[0]=Path=/api/auth/**
spring.cloud.gateway.routes[0].filters[0]=StripPrefix=1

# PATIENT SERVICE
spring.cloud.gateway.routes[1].id=patient-service
spring.cloud.gateway.routes[1].uri=http://localhost:8082
spring.cloud.gateway.routes[1].predicates[0]=Path=/api/patients/**
spring.cloud.gateway.routes[1].filters[0]=StripPrefix=1

# DOCTOR SERVICE
spring.cloud.gateway.routes[2].id=doctor-service
spring.cloud.gateway.routes[2].uri=http://localhost:8083
spring.cloud.gateway.routes[2].predicates[0]=Path=/api/doctors/**
spring.cloud.gateway.routes[2].filters[0]=StripPrefix=1

# APPOINTMENT SERVICE
spring.cloud.gateway.routes[3].id=appointment-service
spring.cloud.gateway.routes[3].uri=http://localhost:8084
spring.cloud.gateway.routes[3].predicates[0]=Path=/api/appointments/**
spring.cloud.gateway.routes[3].filters[0]=StripPrefix=1

# MEDICAL RECORD SERVICE
spring.cloud.gateway.routes[4].id=medical-record-service
spring.cloud.gateway.routes[4].uri=http://localhost:8085
spring.cloud.gateway.routes[4].predicates[0]=Path=/api/medical-records/**
spring.cloud.gateway.routes[4].filters[0]=StripPrefix=1

# CONTACT MESSAGE
spring.cloud.gateway.routes[5].id=contact-message-route
spring.cloud.gateway.routes[5].uri=http://localhost:8082
spring.cloud.gateway.routes[5].predicates[0]=Path=/api/v1/contact-messages
spring.cloud.gateway.routes[5].filters[0]=StripPrefix=0

# USERS (AUTH SERVICE)
spring.cloud.gateway.routes[6].id=users-service
spring.cloud.gateway.routes[6].uri=http://localhost:8081
spring.cloud.gateway.routes[6].predicates[0]=Path=/api/users/**
spring.cloud.gateway.routes[6].filters[0]=StripPrefix=0

# =====================================
# SECURITY & JWT (ZERO-LEAK PLACEHOLDER)
# =====================================
# Ganti dengan secret key HMAC-SHA 256/512 acak minimal 32/64 karakter alfanumerik.
jwt.secret-key=${JWT_SECRET_KEY:YOUR_SECURE_RANDOM_SECRET_KEY_MIN_32_CHARS}

# =====================================
# LOGGING
# =====================================
spring.jpa.open-in-view=false
logging.level.org.springframework.cloud.gateway=DEBUG
logging.level.org.springframework.security=DEBUG
